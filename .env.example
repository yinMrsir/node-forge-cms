# ==========================================
# NodeForgeCMS Docker 环境配置文件
# ==========================================
# 部署前请复制此文件为 .env 并修改相关配置

# ==========================================
# MySQL 数据库配置
# ==========================================
MYSQL_ROOT_PASSWORD=nodeforge_root_password_change_me
MYSQL_DATABASE=node_forge_cms
MYSQL_USER=nodeforge
MYSQL_PASSWORD=nodeforge_password_change_me
MYSQL_PORT=3306

# ==========================================
# Redis 缓存配置
# ==========================================
REDIS_PASSWORD=redis_password_change_me
REDIS_PORT=6379

# ==========================================
# JWT 密钥 (必须修改为随机字符串)
# ==========================================
JWT_SECRET=your_jwt_secret_key_change_in_production

# ==========================================
# 服务域名配置
# ==========================================
# 生产环境请修改为实际域名，如: https://example.com
SERVER_HOST=http://localhost
IMG_HOST=http://localhost
IS_DEMO_ENVIRONMENT=false

# ==========================================
# 端口配置
# ==========================================
# Nginx 对外端口
NGINX_HTTP_PORT=80
NGINX_HTTPS_PORT=443
# 应用直接访问端口
APP_PORT=3000

# ==========================================
# 邮件配置 (可选)
# ==========================================
# 用户发送邮件的邮箱
FORM_USER_EMAIL=
# 用户发送邮件的邮箱密码 (QQ邮箱请使用授权码)
FORM_USER_EMAIL_PASSWORD=
# 邮件服务提供商 (QQ, Gmail, 163等)
USER_EMAIL_SERVICE=QQ
